  "type": "module",
  "description": "Finance dashboard backend with role-based access control and concurrency-safe updates",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext js,json --ignore node_modules --exec \"node src/server.js\"",
    "start": "node src/server.js",
